{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "format": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "start:dev": {
      "persistent": true,
      "cache": false
    },
    "prisma:generate": {
      "outputs": ["node_modules/.prisma/**"]
    },
    "prisma:migrate:dev": {
      "cache": false
    },
    "prisma:migrate:deploy": {
      "cache": false
    }
  }
}
